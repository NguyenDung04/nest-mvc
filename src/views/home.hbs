<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  <link rel="stylesheet" href="/public/css/output.css" />
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="max-w-4xl mx-auto py-16 px-6">
    <div class="bg-white rounded-2xl shadow p-8">
      <h1 class="text-3xl font-bold text-gray-800 mb-4">{{title}}</h1>
      <p class="text-gray-600 mb-6">{{message}}</p>

      <div class="space-y-2 text-sm text-gray-700">
        <p><strong>Health:</strong> <a class="text-blue-600" href="/health">/health</a></p>
        <p><strong>Swagger:</strong> <a class="text-blue-600" href="/docs">/docs</a></p>
        <p><strong>API prefix:</strong> /api</p>
        <p><strong>CSRF token:</strong> {{csrfToken}}</p>
      </div>
    </div>
  </div>
</body>
</html>